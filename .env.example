# 对话（OpenAI 兼容，DeepSeek 示例）
# DEEPSEEK_API_KEY=
# 或与生态工具共用的名称：
# OPENAI_API_KEY=

# 对话 Base URL（无尾斜杠）。DeepSeek：https://api.deepseek.com ；OpenAI 官方：https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com

# 对话模型
# QIAOPI_LLM_MODEL=deepseek-v4-flash

# 转写：用户输入最大字符数（超出 400）
# QIAOPI_MAX_INPUT_CHARS=1500

# 转写：期望模型输出约上限（写入 system 提示）
# QIAOPI_MAX_OUTPUT_CHARS=600

# 信笺页 /letter 底部文案（客户端可读，需 NEXT_PUBLIC_ 前缀）
# NEXT_PUBLIC_QIAOPI_CINEMA_BRAND=某某影城
# NEXT_PUBLIC_QIAOPI_MOVIE_LINE=《给阿嬷的情书》· 主题呈现
